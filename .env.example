# Forum Posts (creates forum threads for each patch note)
FORUM_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_FORUM_ID/YOUR_FORUM_TOKEN
FORUM_TAGS={"patch": "TAG_ID_FOR_PATCHES", "leak": "TAG_ID_FOR_LEAKS"}
PATCH_NOTES_POLL_MINUTES=30

# Daily Shop (optional — feature disabled if not set)
DAILY_SHOP_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_SHOP_ID/YOUR_SHOP_TOKEN
RIOT_USERNAME=your_riot_username
RIOT_PASSWORD=your_riot_password
RIOT_SSID_COOKIE=
RIOT_REGION=ap
RIOT_DISPLAY_NAME=
RIOT_PROXY_URL=

# Session Recap (optional — run via session_recap.py)
SESSION_RECAP_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_SESSION_ID/YOUR_SESSION_TOKEN
TEAM_PUUIDS=puuid1,puuid2,puuid3
HENRIK_API_KEY=HDEV-xxxx-xxxx-xxxx
HENRIK_API_REGION=ap
